<script>


let musicStarted = false;
let targetVolume = 1.0;

document.addEventListener("DOMContentLoaded", () => {

  let index = 0;
  let finished = false;
  let musicStarted = false;
  let targetVolume = 1.0;

  const music = document.getElementById("music");
  const slider = document.getElementById("volumeSlider");

  // ---------- SLIDES ----------
  function showSlide(i) {
    let slides = document.getElementsByClassName("slide");

    for (let s of slides) {
      s.style.display = "none";
    }

    slides[i].style.display = "block";
  }

  window.nextSlide = function () {
    startMusic();

    let slides = document.getElementsByClassName("slide");

    if (index < slides.length - 1) {
      index++;
      showSlide(index);
    } else if (!finished) {
      finished = true;

      setTimeout(() => {
        let msg = document.getElementById("finalMessage");
        msg.style.display = "block";
        setTimeout(() => msg.classList.add("show"), 10);
      }, 1000);
    }
  };

  window.prevSlide = function () {
    if (index > 0) index--;
    showSlide(index);
  };

  showSlide(index);

  // ---------- SLIDER ----------
  if (slider) {
    slider.addEventListener("input", () => {
      targetVolume = parseFloat(slider.value);
      if (musicStarted) music.volume = targetVolume;
    });
  }

  // ---------- MUSIC ----------
  function startMusic() {
    if (musicStarted || !music) return;

    musicStarted = true;

    music.volume = 0;
    music.play();

    let fade = setInterval(() => {
      if (music.volume < targetVolume) {
        music.volume += 0.05;
      } else {
        music.volume = targetVolume;
        clearInterval(fade);
      }
    }, 100);
  }

  window.startMusic = startMusic;

});


const music = document.getElementById("music");

music.addEventListener("timeupdate", () => {
  const fadeDuration = 0.75; // seconds before end to start fading

  if (music.duration - music.currentTime <= fadeDuration) {
    fadeOutAndRestart();
  }
});

let isLooping = false;

function fadeOutAndRestart() {
  if (isLooping) return;
  isLooping = true;

  let fade = setInterval(() => {
    if (music.volume > 0.05) {
      music.volume -= 0.05;
    } else {
      clearInterval(fade);

      music.currentTime = 0;
      fadeIn();

      isLooping = false;
    }
  }, 100);
}

function fadeIn() {
  music.volume = 0;

  let fade = setInterval(() => {
    if (music.volume < 0.8) {
      music.volume += 0.05;
    } else {
      music.volume = targetVolume;
      clearInterval(fade);
    }
  }, 100);
}




</script>

